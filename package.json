{
  "name": "ant-agent",
  "version": "1.0.0",
  "description": "Autonomous AI Trading Colony powered by OpenClaw - Multi-agent AI trading system on Solana",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "build:prod": "npm run clean && npm run build",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky install",
    "docs": "typedoc --out docs/api src",
    "release": "semantic-release"
  },
  "keywords": [
    "ai",
    "trading",
    "solana",
    "openclaw",
    "agent",
    "multi-agent",
    "autonomous",
    "defi",
    "dex",
    "cryptocurrency",
    "blockchain",
    "colony",
    "machine-learning"
  ],
  "author": "ANT AGENT Team <contact@antagent.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ant-agent/ant-agent.git"
  },
  "bugs": {
    "url": "https://github.com/ant-agent/ant-agent/issues"
  },
  "homepage": "https://github.com/ant-agent/ant-agent#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@metaplex-foundation/js": "^0.20.0",
    "@openclaw/core": "^2.0.0",
    "@openclaw/agents": "^2.0.0",
    "@solana/spl-token": "^0.3.9",
    "@solana/web3.js": "^1.87.0",
    "axios": "^1.6.0",
    "bs58": "^5.0.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.3.1",
    "eventemitter3": "^5.0.1",
    "jupiter-aggregator-sdk": "^1.0.0",
    "lodash": "^4.17.21",
    "pino": "^8.17.0",
    "raydium-sdk": "^1.3.1-beta.54",
    "typescript": "^5.3.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "semantic-release": "^22.0.8",
    "tsx": "^4.6.0",
    "tsc-alias": "^1.8.8",
    "typedoc": "^0.25.4",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@openclaw/core": "^2.0.0",
    "@solana/web3.js": "^1.87.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "vitest": {
    "include": [
      "tests/**/*.test.ts"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json",
        "html"
      ],
      "thresholds": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    }
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}
