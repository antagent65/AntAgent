# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# SOLANA CONFIGURATION
# ============================================

# Solana RPC endpoint (mainnet, devnet, or custom)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# WebSocket endpoint for real-time updates (optional)
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Commitment level: processed | confirmed | finalized
SOLANA_COMMITMENT=confirmed

# Wallet private key (base64 encoded)
# NEVER commit this to version control!
WALLET_PRIVATE_KEY=

# ============================================
# OPENCLAW CONFIGURATION
# ============================================

# OpenClaw API key
OPENCLAW_API_KEY=

# Colony identifier
OPENCLAW_COLONY=ant-agent-main

# Heartbeat interval in milliseconds
OPENCLAW_HEARTBEAT_INTERVAL=30000

# Enable learning loops
OPENCLAW_ENABLE_LEARNING=true

# ============================================
# TRADING CONFIGURATION
# ============================================

# Maximum allowed slippage (%)
MAX_SLIPPAGE=2.5

# Default transaction priority: low | medium | high
DEFAULT_PRIORITY=high

# Maximum position size in USD
MAX_POSITION_SIZE=1000

# Stop loss percentage (optional)
STOP_LOSS=5

# Take profit percentage (optional)
TAKE_PROFIT=10

# Daily loss limit in USD (optional)
DAILY_LOSS_LIMIT=500

# ============================================
# AGENT CONFIGURATION
# ============================================

# Maximum number of scout agents
MAX_SCOUTS=5

# Maximum number of analyst agents
MAX_ANALYSTS=5

# Maximum number of executor agents
MAX_EXECUTORS=3

# Enable learning agents
LEARNING_ENABLED=true

# ============================================
# $ANT TOKEN CONFIGURATION
# ============================================

# $ANT token mint address
ANT_TOKEN_MINT=

# Staking contract address
ANT_STAKING_CONTRACT=

# ============================================
# API CONFIGURATION
# ============================================

# API server port
API_PORT=3000

# API rate limit (requests per minute)
API_RATE_LIMIT=100

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE=logs/ant-agent.log

# Enable console logging
LOG_CONSOLE=true

# ============================================
# NETWORK SELECTION
# ============================================

# Choose network: mainnet-beta | devnet | testnet
SOLANA_NETWORK=mainnet-beta

# RPC URLs for different networks
SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
SOLANA_TESTNET_RPC=https://api.testnet.solana.com
